<script>

// ⚙️ AYARLAR - BURAYA KENDİ DEĞERLERİNİ YAZ
const CONFIG = {
    SERVER_IP: "play.vanirmc.com",
    DISCORD_INVITE: "https://discord.gg/vanirmc"
};

// IP Kopyala
function copyIP(){
    navigator.clipboard.writeText(CONFIG.SERVER_IP);
    const btn = event.target;
    const originalText = btn.innerText;
    btn.innerText = "✅ Kopyalandı!";
    btn.classList.add("bg-green-600");
    
    setTimeout(() => {
        btn.innerText = originalText;
        btn.classList.remove("bg-green-600");
    }, 2000);
}

// Rank Satın Al
function buyRank(rankName, price){
    alert(`${rankName} rankını satın almak için destek ekibimizle iletişime geçiniz!\n\nFiyat: ${price}₺\n\nDiscord: ${CONFIG.DISCORD_INVITE}`);
    // Gerçek ödeme sistemi için Stripe/PayPal entegrasyonu ekle
}

// Sunucu Durumu Kontrol
async function serverStatus(){
    try{
        let res = await fetch("https://api.mcsrvstat.us/2/" + CONFIG.SERVER_IP);
        let data = await res.json();
        
        if(data.online){
            document.getElementById("status").innerText = "🟢 Online";
            document.getElementById("players").innerText = (data.players.online || 0) + " / " + (data.players.max || "∞");
        }else{
            document.getElementById("status").innerText = "🔴 Offline";
            document.getElementById("players").innerText = "0";
        }
    }catch(err){
        document.getElementById("status").innerText = "⚠️ Hata";
        console.log("Server status check failed:", err);
    }
}

// Sayfa yüklenince başla
document.addEventListener('DOMContentLoaded', function(){
    serverStatus();
    setInterval(serverStatus, 30000); // Her 30 saniyede bir kontrol et
});

// Smooth scroll
document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function (e) {
        e.preventDefault();
        const target = document.querySelector(this.getAttribute('href'));
        if(target) target.scrollIntoView({behavior: 'smooth'});
    });
});

</script>

